# Node.js standard .gitignore

# Logs
logs/
npm-debug.log* 
yarn-debug.log* 
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov/

# Coverage directory used by tools like istanbul
coverage/

# dependency directories
node_modules/ 
bower_components/

# Environment variable files
.env

# Output of 'npm pack'
*.tgz

# Operating System Files
.DS_Store
Thumbs.db
